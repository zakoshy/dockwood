rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Products are publicly readable for the storefront, but only authenticated admins can modify them.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Sales and Deliveries contain sensitive business data and are restricted to authenticated admins.
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    match /deliveries/{deliveryId} {
      allow read, write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}