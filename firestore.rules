
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Products: Publicly readable for the storefront.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Warehouses: Restricted to authenticated admins only.
    match /warehouses/{warehouseId} {
      allow read, write: if request.auth != null;
    }

    // Sales: Restricted to authenticated admins only.
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    // Deliveries: Restricted to authenticated admins only.
    match /deliveries/{deliveryId} {
      allow read, write: if request.auth != null;
    }

    // Interactions: Public can create (to track stats), only admin can read.
    match /interactions/{interactionId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    
    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
