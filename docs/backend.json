
{
  "entities": {
    "Warehouse": {
      "title": "Warehouse",
      "description": "A physical location or stall where products are stored.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "A timber or furniture product in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "warehouseId": { "type": "string", "description": "The ID of the warehouse entity." },
        "warehouseLocation": { "type": "string", "description": "Legacy text location/stall name." },
        "imageUrls": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "sku": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A recorded transaction of a product sale.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["mpesa", "cash", "bank"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "productId", "quantity", "totalAmount"]
    },
    "Delivery": {
      "title": "Delivery",
      "description": "A logistics entry for tracking a delivery.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "items": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Out for Delivery", "Delivered", "Cancelled"] },
        "urgency": { "type": "string", "enum": ["Normal", "Medium", "High"] },
        "cost": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "location", "status"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A log of user interaction on the public website.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["visit", "inquiry", "view_product"] },
        "page": { "type": "string" },
        "productName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/warehouses/{warehouseId}": {
      "schema": "Warehouse",
      "description": "Physical warehouse locations."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products in the catalog."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "History of all sales transactions."
    },
    "/deliveries/{deliveryId}": {
      "schema": "Delivery",
      "description": "Tracking logs for all deliveries."
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Log of user activity for analytics."
    }
  }
}
